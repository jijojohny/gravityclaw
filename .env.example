# ==============================================
# GravityClaw Environment Configuration
# ==============================================
# Copy this file to .env and fill in the values

# App Configuration
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gravityclaw

# Redis
REDIS_URL=redis://localhost:6379

# ==============================================
# Authentication (Privy)
# ==============================================
# Get your keys at https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# ==============================================
# 0G Network Configuration
# ==============================================
# Testnet
OG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602
OG_INDEXER_RPC=https://indexer-testnet.0g.ai

# Mainnet (uncomment for production)
# OG_CHAIN_RPC=https://evmrpc.0g.ai
# OG_CHAIN_ID=16661
# OG_INDEXER_RPC=https://indexer.0g.ai

# Deployer/Operator Private Key (without 0x prefix)
# WARNING: Keep this secure! Use environment variables in production
OG_PRIVATE_KEY=your-private-key-here

# ==============================================
# Smart Contract Addresses
# ==============================================
# Deploy contracts first, then add addresses here
CONTRACT_INSTANCE_REGISTRY=
CONTRACT_SUBSCRIPTION=
CONTRACT_TREASURY=

# ==============================================
# Stripe Payments
# ==============================================
# Get your keys at https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
# Recurring Price ids from Stripe Products (used by prisma seed → Plan.stripePriceId)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
# Return URL after Stripe Customer Portal (optional; defaults to localhost dashboard)
STRIPE_BILLING_RETURN_URL=http://localhost:3001/dashboard

# Usage ingest: required in production for POST /api/usage/record (X-Internal-Secret header)
USAGE_INGEST_SECRET=

# ==============================================
# Telegram
# ==============================================
TELEGRAM_API_URL=https://api.telegram.org

# ==============================================
# Security
# ==============================================
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# ==============================================
# Monitoring (Optional)
# ==============================================
SENTRY_DSN=
LOG_LEVEL=info
